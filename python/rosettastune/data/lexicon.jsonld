    {
      "@id": "stune:Pa",
      "canonical": "Pa",
      "dimension": "pressure",
      "aliases": ["qudt:PA", "om:pascal", "unece:PAL", "iof_adapter:pressure/Pa"]
    },
    {
      "@id": "stune:J_per_kg",
      "canonical": "J/kg",
      "dimension": "specific_energy",
      "aliases": ["qudt:J-PER-KiloGM", "om:joulePerKilogram", "iof_adapter:specific_energy/J_per_kg"]
    },
    {
      "@id": "stune:degC",
      "canonical": "degC",
      "dimension": "temperature",
      "aliases": ["qudt:DEG_C", "om:degreeCelsius", "unece:CEL", "iof_adapter:temperature/degC"]
